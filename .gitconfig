[user]
	name = ajt
	email = github@thorntonindustries.com

[alias]
	c = commit -am
	s = status -s
	co = checkout
	cb = checkout -b
	up = pull
	p = push
	df = diff
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
	d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

	# recent branches
	recent = branch --sort=-committerdate --format='%(committerdate:relative)%09%(refname:short)'

	# undo last commit (keep changes staged)
	undo = reset --soft HEAD~1

	# amend without editing message
	amend = commit --amend --no-edit

	# list aliases
	aliases = config --get-regexp alias

[core]
	excludesfile = ~/.gitignore_global
	# use delta for paging diffs (falls back to less if delta not installed)
	pager = "delta 2>/dev/null || less"

[interactive]
	diffFilter = "delta --color-only 2>/dev/null || cat"

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[color]
	ui = always
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[push]
	default = current
	autoSetupRemote = true   # auto set upstream on first push

[pull]
	rebase = true

[init]
	defaultBranch = main

[help]
	autocorrect = 1

[url "git@github.com:"]
	insteadOf = "gh:"
	pushInsteadOf = "https://github.com/"

[url "git@github.com:ajt/"]
	insteadOf = "git://github.com/ajt/"

[include]
	# machine-specific: credentials, tokens, signing
	path = ~/.gitconfig.local
