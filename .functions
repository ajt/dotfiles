# Create a new directory and enter it
md() {
  mkdir -p "$@" && cd "$@"
}

# find shorthand (though `fd` is faster for most things)
f() {
  find . -name "$1" 2>&1 | grep -v 'Permission denied'
}

# cd into whatever is the forefront Finder window
cdf() {
  cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')"
}

# Start an HTTP server from a directory
server() {
  local port="${1:-8000}"
  open "http://localhost:${port}/"
  python3 -m http.server "$port"
}

# Copy w/ progress
cp_p() {
  rsync -WavP --human-readable --progress "$1" "$2"
}

# Pretty-print JSON (pipe or argument)
json() {
  if [ -p /dev/stdin ]; then
    python3 -mjson.tool | bat -l json 2>/dev/null || python3 -mjson.tool
  else
    python3 -mjson.tool <<< "$*" | bat -l json 2>/dev/null || python3 -mjson.tool <<< "$*"
  fi
}

# Get gzipped size
gz() {
  echo "orig size    (bytes):"
  cat "$1" | wc -c
  echo "gzipped size (bytes):"
  gzip -c "$1" | wc -c
}

# whois a domain or a URL
whois() {
  local domain=$(echo "$1" | awk -F/ '{print $3}')
  if [ -z "$domain" ]; then
    domain=$1
  fi
  echo "Getting whois record for: $domain …"
  /usr/bin/whois -h whois.internic.net "$domain" | sed '/NOTICE:/q'
}

# Extract archives
extract() {
  if [ -f "$1" ]; then
    case $1 in
      *.tar.bz2) tar xjf "$1"    ;;
      *.tar.gz)  tar xzf "$1"    ;;
      *.tar.xz)  tar Jxvf "$1"   ;;
      *.tar.zst) tar --zstd -xf "$1" ;;
      *.tar)     tar xf "$1"     ;;
      *.bz2)     bunzip2 "$1"    ;;
      *.gz)      gunzip "$1"     ;;
      *.zip)     unzip "$1"      ;;
      *.7z)      7z x "$1"       ;;
      *.rar)     unrar x "$1"    ;;
      *)         echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# animated gifs from any video
gifify() {
  if [[ -n "$1" ]]; then
    ffmpeg -i "$1" -s 600x400 -pix_fmt rgb24 -r 10 -f gif - | gifsicle --optimize=3 --delay=3 > "$1.gif"
  else
    echo "usage: gifify <input_movie.mov>"
  fi
}

# Quick port check — what's running on a port?
port() {
  lsof -i ":${1:-8000}"
}

# Kill whatever's on a port
killport() {
  lsof -ti ":${1}" | xargs kill -9
}

# quick docker cleanup
docker-clean() {
  docker system prune -af --volumes
}

# shellswitch: `shellswitch bash` or `shellswitch zsh`
shellswitch() {
  chsh -s "$(brew --prefix)/bin/$1"
}

# cwork — spin up a Claude Code worktree session for a GitHub issue.
#
#   cwork <issue> [extra instructions...]   open the session in a new tmux window
#   cwork -f <issue> [extra...]             run right here, no tmux
#   cwork -T file <issue> [extra...]        use a specific prompt template for this run
#   cwork -b main <issue>                   branch off main instead of dev (default: dev)
#   cwork -p feature <issue>                force a branch prefix (skip label detection)
#   cwork -y <issue>                        skip the confirmation prompt
#   cwork -n <issue>                        dry run: print the plan and exit
#
# tmux behavior (the default): each run gets its own window.
#   - inside tmux: a new window is added to the current session, focus stays put
#     (so you can fire several in a row)
#   - outside tmux: a session is created (or reused) and you're attached to it
#
# Prompt template: the kickoff prompt is rendered from a template file.
#   Lookup order:  -T <file>  →  $CWORK_TEMPLATE  →  <repo>/.cwork/prompt.md
#                  →  ~/.cwork/prompt.md  →  a built-in fallback
#                  ("Please work issue #<n>.")
#   Placeholders:  {{num}} {{title}} {{branch}} {{url}} {{labels}} {{body}} {{extra}}
#   Trailing text on the command line fills {{extra}}; if the template has no
#   {{extra}}, that text is appended instead. ({{body}} is fetched only if used.)
#
# Self-contained: needs `gh`, `git`, `tmux`, and your repo's `make worktree-add`.
#
# Optional env knobs:
#   CWORK_YES=1        always skip confirmation
#   CWORK_SESSION=name session to use when started outside tmux (default: cwork)
#   CWORK_TEMPLATE=…   default template file (overrides the repo's .cwork/prompt.md)
#   CWORK_SUFFIX="..." always appended to the prompt, e.g.
#                      export CWORK_SUFFIX="Open a PR against dev and merge when green."

cwork() {
  emulate -L zsh
  setopt local_options err_return pipe_fail

  local foreground=0 assume_yes=0 dry_run=0 force_prefix="" base="" opt_template=""
  [[ -n $CWORK_YES ]] && assume_yes=1

  local opt
  while getopts ":fyb:p:nhT:" opt; do
    case $opt in
      f) foreground=1 ;;
      y) assume_yes=1 ;;
      b) base=$OPTARG ;;
      p) force_prefix=$OPTARG ;;
      T) opt_template=$OPTARG ;;
      n) dry_run=1 ;;
      h) print -r -- "usage: cwork [-f] [-y] [-n] [-T template] [-b base] [-p prefix] <issue#> [extra...]"; return 0 ;;
      \?) print -u2 -- "cwork: unknown option -$OPTARG"; return 2 ;;
      :)  print -u2 -- "cwork: -$OPTARG needs an argument"; return 2 ;;
    esac
  done
  shift $((OPTIND - 1))

  local num=$1; shift 2>/dev/null
  [[ -n $num && $num == <-> ]] \
    || { print -u2 -- "cwork: first argument must be an issue number"; return 2; }
  local extra="$*"

  # --- preflight ---
  command -v gh >/dev/null || { print -u2 -- "cwork: gh CLI not found"; return 1; }
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || { print -u2 -- "cwork: not inside a git repo"; return 1; }
  (( foreground || dry_run )) || command -v tmux >/dev/null \
    || { print -u2 -- "cwork: tmux not found (use -f to run without it)"; return 1; }

  # --- fetch issue fields (one call; gh bundles jq via --jq) ---
  local data
  data=$(gh issue view "$num" --json title,state,labels,url \
        --jq '[.title, .state, (.labels|map(.name)|join(" ")), .url] | @tsv' 2>/dev/null) \
    || { print -u2 -- "cwork: couldn't read issue #$num (exists? authed?)"; return 1; }
  local title state labels url
  IFS=$'\t' read -r title state labels url <<< "$data"
  [[ $state == OPEN ]] || print -u2 -- "cwork: heads up — issue #$num is $state"

  # --- build branch name: prefix from labels, slug from title ---
  local prefix=$force_prefix
  if [[ -z $prefix ]]; then
    case " $labels " in
      *" bug "*)                        prefix=bug ;;
      *" enhancement "*|*" feature "*)  prefix=feature ;;
      *" documentation "*)              prefix=docs ;;
      *)                                prefix=task ;;
    esac
  fi
  local slug
  slug=$(print -r -- "$title" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/^[[:space:]]*(feat|feature|fix|bug|bugfix|hotfix|docs?|chore|refactor|perf|test|build|ci|style|revert|task|enhancement)(\([^)]*\))?[[:space:]]*:[[:space:]]*//' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' \
        | cut -c1-48 | sed -E 's/-+$//')
  local branch="${prefix}/${num}-${slug}"
  [[ -n $slug ]] || branch="${prefix}/${num}"

  # --- assemble the kickoff prompt from a template ---
  local repo tmpl_file tmpl_src template
  repo=$(git rev-parse --show-toplevel)
  tmpl_file=${opt_template:-${CWORK_TEMPLATE:-$repo/.cwork/prompt.md}}
  if [[ -f $tmpl_file ]]; then
    template=$(<"$tmpl_file"); tmpl_src=$tmpl_file
  elif [[ -n $opt_template ]]; then
    print -u2 -- "cwork: template not found: $opt_template"; return 1
  elif [[ -f $HOME/.cwork/prompt.md ]]; then
    template=$(<"$HOME/.cwork/prompt.md"); tmpl_src=$HOME/.cwork/prompt.md
  else
    template='Please work issue #{{num}}.'; tmpl_src='(built-in)'
  fi

  local body=""
  [[ $template == *'{{body}}'* ]] && body=$(gh issue view "$num" --json body --jq '.body' 2>/dev/null)

  local had_extra_ph=0
  [[ $template == *'{{extra}}'* ]] && had_extra_ph=1

  local prompt=$template
  prompt=${prompt//'{{num}}'/$num}
  prompt=${prompt//'{{title}}'/$title}
  prompt=${prompt//'{{branch}}'/$branch}
  prompt=${prompt//'{{labels}}'/$labels}
  prompt=${prompt//'{{url}}'/$url}
  prompt=${prompt//'{{body}}'/$body}
  prompt=${prompt//'{{extra}}'/$extra}
  (( had_extra_ph )) || { [[ -n $extra ]] && prompt+=$'\n\n'"$extra"; }
  [[ -n $CWORK_SUFFIX ]] && prompt+=$'\n\n'"$CWORK_SUFFIX"

  # --- show the plan ---
  print -r -- "issue     #${num}  [${state}]  ${title}"
  print -r -- "branch    ${branch}${base:+   (base: $base)}"
  print -r -- "template  ${tmpl_src}"
  print -r -- "──── prompt ────"
  print -r -- "$prompt"
  print -r -- "────────────────"
  (( dry_run )) && return 0
  if (( ! assume_yes )); then
    print -n -- "proceed? [Y/n] "
    local ans; read -r ans
    [[ -z $ans || $ans == [Yy]* ]] || { print -- "aborted."; return 1; }
  fi

  # --- create + provision the worktree via your Makefile ---
  local -a base_arg
  [[ -n $base ]] && base_arg=(BASE="$base")
  make worktree-add BRANCH="$branch" "${base_arg[@]}" || return

  # --- find where the worktree landed, cd in, launch claude ---
  local wt
  wt=$(git worktree list --porcelain | awk -v b="refs/heads/$branch" '
        /^worktree /{p=substr($0,10)}
        /^branch /{if(substr($0,8)==b){print p; exit}}')
  [[ -d $wt ]] \
    || { print -u2 -- "cwork: created branch but couldn't locate its worktree"; return 1; }
  print -- "worktree  ${wt}"

  if (( foreground )); then
    cd "$wt" && claude "$prompt"
    return
  fi

  local win=${branch##*/}                 # 557-bug-make-api-…
  local sess=${CWORK_SESSION:-cwork}
  local cmd="cd ${(q)wt} && claude ${(q)prompt}; exec ${SHELL:-zsh}"

  if [[ -n $TMUX ]]; then
    # already in tmux: add a window to this session, don't steal focus
    tmux new-window -d -n "$win" "$cmd"
    print -- "opened tmux window: ${win}"
  else
    # not in tmux: ensure a session exists, add the window, attach to it
    if tmux has-session -t "$sess" 2>/dev/null; then
      tmux new-window -t "$sess" -n "$win" "$cmd"
    else
      tmux new-session -d -s "$sess" -n "$win" "$cmd"
    fi
    print -- "attaching to tmux session '${sess}', window: ${win}"
    tmux attach -t "$sess"
  fi
}

# --- optional: tab-complete the issue number with open issues + titles ---
_cwork() {
  local -a issues
  issues=(${(f)"$(gh issue list --state open --limit 50 \
      --json number,title --jq '.[] | "\(.number):\(.title)"' 2>/dev/null)"})
  _describe -t issues 'open issue' issues
}
compdef _cwork cwork 2>/dev/null
