# ─── Editor ──────────────────────────────────────────────────────────
export EDITOR="vim"
export VISUAL="vim"

# ─── Pager ───────────────────────────────────────────────────────────
export MANPAGER="less -X"
export LESSSECURE=1  # don't let less be a GTFOBin

# highlighting inside manpages
export LESS_TERMCAP_mb=$(printf '\e[01;31m')       # blinking - red
export LESS_TERMCAP_md=$(printf '\e[01;35m')       # bold - magenta
export LESS_TERMCAP_me=$(printf '\e[0m')           # end mode
export LESS_TERMCAP_se=$(printf '\e[0m')           # end standout
export LESS_TERMCAP_so=$(printf '\e[01;33m')       # standout - yellow
export LESS_TERMCAP_ue=$(printf '\e[0m')           # end underline
export LESS_TERMCAP_us=$(printf '\e[04;36m')       # underline - cyan

# ─── Locale ──────────────────────────────────────────────────────────
export LC_ALL="en_US.UTF-8"
export LANG="en_US.UTF-8"

# ─── Homebrew ────────────────────────────────────────────────────────
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
export HOMEBREW_NO_ANALYTICS=1

# ─── fzf ─────────────────────────────────────────────────────────────
# use fd for fzf (fast, respects .gitignore)
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_CTRL_T_OPTS="--preview 'bat -n --color=always {} 2>/dev/null || tree -C {}'"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

# ─── LS colors ───────────────────────────────────────────────────────
# eza handles its own colors, but keep this for anything that uses LS_COLORS
command -v gdircolors >/dev/null 2>&1 || alias gdircolors="dircolors"
[[ -f ~/.dircolors ]] && eval "$(gdircolors -b ~/.dircolors)"

# ─── tmux ────────────────────────────────────────────────────────────
export DISABLE_AUTO_TITLE=true

# ─── PATH additions ─────────────────────────────────────────────────
# local bin
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"
