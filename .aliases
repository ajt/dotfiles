# ─── Navigation ──────────────────────────────────────────────────────
alias ..="cd .."
alias cd..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias -- -="cd -"

# ─── Safety ──────────────────────────────────────────────────────────
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"

# ─── Modern replacements ────────────────────────────────────────────
# eza > ls (install: brew install eza)
if command -v eza &>/dev/null; then
  alias ls="eza --icons --group-directories-first"
  alias la="eza -la --icons --group-directories-first"
  alias ll="eza -l --icons --group-directories-first"
  alias lt="eza --tree --level=2 --icons"
  alias lsd="eza -lD --icons"  # directories only
else
  alias ls="ls --color=auto"
  alias la="ls -la"
  alias ll="ls -l"
fi

# bat > cat (install: brew install bat)
if command -v bat &>/dev/null; then
  alias cat="bat --paging=never"
fi

# ripgrep > grep/ag/ack
if command -v rg &>/dev/null; then
  alias grep="rg"
fi

# ─── Git ─────────────────────────────────────────────────────────────
alias g="git"
alias gs="git status -s"
alias ga="git add"
alias gc="git commit"
alias gco="git checkout"
alias gb="git branch"
alias gd="git diff"
alias gl="git log --oneline --graph --decorate -20"
alias gp="git push"
alias gpu="git pull"
alias gr='[ ! -z $(git rev-parse --show-cdup 2>/dev/null) ] && cd $(git rev-parse --show-cdup || pwd)'
alias cgs="clear && git status"

# ─── tmux ────────────────────────────────────────────────────────────
alias tks="tmux kill-session"
alias tkill="tmux kill-server"
alias tls="tmux list-sessions"
alias ta="tmux attach -t"
alias mux="tmuxinator"

# ─── Python ──────────────────────────────────────────────────────────
alias py="python3"
alias rmpyc="find . -name '*.pyc' -delete && find . -name '__pycache__' -type d -delete"

# ─── Shortcuts ───────────────────────────────────────────────────────
alias v="vim"
alias cls="clear && ls"
alias cll="clear && ls -lasrth"
alias where=which
alias please=sudo
alias hosts='sudo $EDITOR /etc/hosts'

# ─── Network ────────────────────────────────────────────────────────
alias ip="curl -s https://ipinfo.io/ip"
alias localip="ipconfig getifaddr en0"
alias ips="ifconfig -a | perl -nle'/(\d+\.\d+\.\d+\.\d+)/ && print \$1'"
alias flush="dscacheutil -flushcache && killall -HUP mDNSResponder"

# ─── Cleanup ─────────────────────────────────────────────────────────
alias cleanup="find . -name '*.DS_Store' -type f -ls -delete"
alias trimcopy="tr -d '\n' | pbcopy"

# ─── File size ───────────────────────────────────────────────────────
alias fs="stat -f '%z bytes'"

# ─── Misc typos ──────────────────────────────────────────────────────
alias brwe=brew
